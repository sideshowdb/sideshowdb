name "Sideshow CLI"
bin "sideshow"
about "Git-backed event-sourced document database CLI"
version "0.1.2"
usage "usage: sideshow [--help] [--json] [--refstore subprocess|github] [--repo owner/name] [--ref refname] <help|version|config|doc|event|snapshot|auth|gh>"
source_code_link_template "https://github.com/sideshowdb/sideshowdb/blob/main/src/cli/{{path}}"

config {
  prop "refstore.kind" \
    default="subprocess" \
    env="SIDESHOWDB_REFSTORE" \
    help="Native document backend selected by --refstore." {
    long_help """
Read from .sideshowdb/config.toml. The matching CLI flag is --refstore and the matching environment variable is SIDESHOWDB_REFSTORE. Precedence is documented on the --refstore flag.
"""
  }
}

flag "--json" global=#true help="Emit machine-readable JSON output for document, event, snapshot, and auth commands."
flag "--help" global=#true help="Print help information."
flag "--refstore <backend>" global=#true env="SIDESHOWDB_REFSTORE" default="subprocess" help="Select the native document backend for this invocation." {
  choices "subprocess" "github"
  long_help """
Native document commands resolve the refstore in this precedence order:

1. --refstore subprocess|github
2. SIDESHOWDB_REFSTORE=subprocess|github
3. .sideshowdb/config.toml
4. built-in default: subprocess

Invalid backend names fail before document state is mutated.

Selecting --refstore github also requires --repo owner/name and resolvable GitHub credentials. Run 'sideshow gh auth login' to provide a personal access token.
"""
}
flag "--repo <owner/name>" global=#true env="SIDESHOWDB_REPO" help="GitHub repository (owner/name) for --refstore github."
flag "--ref <refname>" global=#true env="SIDESHOWDB_REF" default="refs/sideshowdb/documents" help="Git ref used by --refstore github. Defaults to refs/sideshowdb/documents."
flag "--api-base <url>" global=#true env="SIDESHOWDB_API_BASE" help="GitHub REST API base URL. Defaults to https://api.github.com."
flag "--credential-helper <helper>" global=#true env="SIDESHOWDB_CREDENTIAL_HELPER" default="auto" help="Credential source for --refstore github. One of: auto, env, gh, git." {
  choices "auto" "env" "gh" "git"
}

cmd "version" help="Print the product banner and package version." {
  long_help "Print the product banner and package version."
  example "$ sideshow version"
}

cmd "help" help="Print help information." {
  long_help "Print top-level help, or help for a command path such as 'sideshow help doc put'."
  example "$ sideshow help"
  example "$ sideshow help doc put"
}

cmd "config" help="Manage SideshowDB configuration values." subcommand_required=#true {
  long_help "Read and edit SideshowDB configuration values."

  cmd "get" help="Print one configuration value." {
    flag "--local" help="Read from the repository-local configuration."
    flag "--global" help="Read from the user-global configuration."
    arg "<key>"
    example "$ sideshow config get refstore.kind"
    example "$ sideshow config get --global refstore.kind"
  }

  cmd "set" help="Set one configuration value." {
    flag "--local" help="Write to the repository-local configuration."
    flag "--global" help="Write to the user-global configuration."
    arg "<key>"
    arg "<value>"
    example "$ sideshow config set refstore.kind github"
    example "$ sideshow config set --local refstore.kind subprocess"
  }

  cmd "unset" help="Remove one configuration value." {
    flag "--local" help="Remove from the repository-local configuration."
    flag "--global" help="Remove from the user-global configuration."
    arg "<key>"
    example "$ sideshow config unset refstore.kind"
  }

  cmd "list" help="List configuration values." {
    flag "--local" help="List repository-local configuration values."
    flag "--global" help="List user-global configuration values."
    example "$ sideshow config list"
  }
}

cmd "doc" help="Manage documents in the Git-backed document store." subcommand_required=#true {
  long_help """
Document commands run against the current working directory's Git repository unless the embedding test harness passes a repository path directly.

Backend selection applies to native document commands. The browser WASM runtime has its own in-WASM MemoryRefStore default and optional TypeScript host store.
"""

  cmd "put" help="Create or replace a document version." {
    flag "--namespace <namespace>" help="Logical namespace. Defaults to default."
    flag "--type <type>" help="Document type. If omitted, the JSON payload may provide it."
    flag "--id <id>" help="Document id. If omitted, the JSON payload may provide it."
    flag "--data-file <path>" help="Read payload bytes from a file instead of stdin." {
      long_help """
--data-file wins when both stdin and --data-file are present.

A missing or unreadable --data-file path returns exit code 1, writes a --data-file error to stderr, and does not mutate document state.
"""
    }

    example "$ echo '{\"title\":\"From stdin\"}' | sideshow --json doc put --type note --id stdin-demo"
    example "$ sideshow --json doc put --type note --id file-demo --data-file payload.json"
  }

  cmd "get" help="Read the current document value, or a specific historical version." {
    flag "--namespace <namespace>" help="Logical namespace. Defaults to default."
    flag "--type <type>" help="Document type."
    flag "--id <id>" help="Document id."
    flag "--version <version>" help="Version id returned by a prior put or history call."

    example "$ sideshow --json doc get --type note --id file-demo"
  }

  cmd "list" help="List documents in the document section." {
    flag "--namespace <namespace>" help="Filter to one namespace."
    flag "--type <type>" help="Filter to one document type."
    flag "--limit <count>" help="Maximum number of items to return."
    flag "--cursor <cursor>" help="Cursor returned by a previous paged response."
    flag "--mode <mode>" default="summary" help="summary returns identity/version metadata; detailed includes document data." {
      choices "summary" "detailed"
    }

    example "$ sideshow --json doc list --type note --mode summary"
  }

  cmd "delete" help="Delete the latest reachable document value." {
    flag "--namespace <namespace>" help="Logical namespace. Defaults to default."
    flag "--type <type>" help="Document type."
    flag "--id <id>" help="Document id."

    example "$ sideshow --json doc delete --type note --id file-demo"
  }

  cmd "history" help="List historical document versions newest-first." {
    flag "--namespace <namespace>" help="Logical namespace. Defaults to default."
    flag "--type <type>" help="Document type."
    flag "--id <id>" help="Document id."
    flag "--limit <count>" help="Maximum number of versions to return."
    flag "--cursor <cursor>" help="Cursor returned by a previous paged response."
    flag "--mode <mode>" default="summary" help="summary returns identity/version metadata; detailed includes historical document data." {
      choices "summary" "detailed"
    }

    example "$ sideshow --json doc history --type note --id file-demo --mode detailed"
  }
}

cmd "event" help="Manage append-only event streams over the Git-backed event store." subcommand_required=#true {
  long_help """
Event commands run against refs/sideshowdb/events in the subprocess refstore.
Use event append to write one single-stream batch and event load to replay stream events.
"""

  cmd "append" help="Append a JSONL or JSON event batch to one stream." {
    flag "--namespace <namespace>" help="Logical namespace."
    flag "--aggregate-type <aggregate_type>" help="Aggregate type."
    flag "--aggregate-id <aggregate_id>" help="Aggregate id."
    flag "--expected-revision <revision>" help="Required current stream revision. Omit to append without revision check."
    flag "--format <format>" default="jsonl" help="Input format for the append payload." {
      choices "jsonl" "json"
    }
    flag "--data-file <path>" help="Read batch payload bytes from a file instead of stdin." {
      long_help """
--data-file wins when both stdin and --data-file are present.

A missing or unreadable --data-file path returns exit code 1, writes a --data-file error to stderr, and does not mutate event state.
"""
    }

    example "$ sideshow --json event append --namespace default --aggregate-type issue --aggregate-id issue-1 --expected-revision 0 --format jsonl < events.jsonl"
    example "$ sideshow --json event append --namespace default --aggregate-type issue --aggregate-id issue-1 --format json --data-file batch.json"
  }

  cmd "load" help="Load events for one stream in append order." {
    flag "--namespace <namespace>" help="Logical namespace."
    flag "--aggregate-type <aggregate_type>" help="Aggregate type."
    flag "--aggregate-id <aggregate_id>" help="Aggregate id."
    flag "--from-revision <revision>" help="Load events from this one-based revision onward."

    example "$ sideshow --json event load --namespace default --aggregate-type issue --aggregate-id issue-1 --from-revision 2"
  }
}

cmd "snapshot" help="Manage stream snapshots over the Git-backed snapshot store." subcommand_required=#true {
  long_help """
Snapshot commands run against refs/sideshowdb/snapshots in the subprocess refstore.
Use snapshot put to store a revision-addressed state snapshot and snapshot get/list to read snapshots.
"""

  cmd "put" help="Store one snapshot for a stream revision." {
    flag "--namespace <namespace>" help="Logical namespace."
    flag "--aggregate-type <aggregate_type>" help="Aggregate type."
    flag "--aggregate-id <aggregate_id>" help="Aggregate id."
    flag "--revision <revision>" help="Snapshot revision (must be > 0)."
    flag "--up-to-event-id <event_id>" help="Event id included by this snapshot."
    flag "--state-file <path>" help="Read required snapshot state JSON from a file instead of stdin."
    flag "--metadata-file <path>" help="Read optional snapshot metadata JSON from a file."

    example "$ sideshow --json snapshot put --namespace default --aggregate-type issue --aggregate-id issue-1 --revision 5 --up-to-event-id evt-5 --state-file snapshot-state.json"
  }

  cmd "get" help="Get the latest snapshot or one at-or-before a revision." {
    flag "--namespace <namespace>" help="Logical namespace."
    flag "--aggregate-type <aggregate_type>" help="Aggregate type."
    flag "--aggregate-id <aggregate_id>" help="Aggregate id."
    flag "--latest" help="Get the highest stored snapshot revision for the stream."
    flag "--at-or-before <revision>" help="Get the highest snapshot revision less than or equal to this revision."

    example "$ sideshow --json snapshot get --namespace default --aggregate-type issue --aggregate-id issue-1 --latest"
    example "$ sideshow --json snapshot get --namespace default --aggregate-type issue --aggregate-id issue-1 --at-or-before 10"
  }

  cmd "list" help="List snapshot metadata newest-first for one stream." {
    flag "--namespace <namespace>" help="Logical namespace."
    flag "--aggregate-type <aggregate_type>" help="Aggregate type."
    flag "--aggregate-id <aggregate_id>" help="Aggregate id."

    example "$ sideshow --json snapshot list --namespace default --aggregate-type issue --aggregate-id issue-1"
  }
}

cmd "auth" help="Manage credentials for remote refstore providers." subcommand_required=#true {
  long_help """
Auth commands manage credentials stored under ~/.config/sideshowdb/hosts.toml (mode 0600).

Tokens are never echoed to the terminal and are never written to argv. Use 'sideshow gh auth login' to authenticate to github.com.
"""

  cmd "status" help="Show authenticated hosts and the active credential source for each." {
    example "$ sideshow auth status"
    example "$ sideshow --json auth status"
  }

  cmd "logout" help="Remove stored credentials for one or all hosts." {
    flag "--host <hostname>" help="Logout of a single host. Omit to remove every entry from hosts.toml."
    example "$ sideshow auth logout --host github.com"
    example "$ sideshow auth logout"
  }
}

cmd "gh" help="GitHub-specific commands." subcommand_required=#true {
  cmd "auth" help="GitHub authentication commands." subcommand_required=#true {
    cmd "login" help="Authenticate to github.com with a personal access token." {
      flag "--with-token" help="Read the token from stdin instead of prompting interactively."
      flag "--skip-verify" help="Persist the token without calling GET /user to verify it."
      long_help """
Interactive mode prompts for a token on /dev/tty with echo disabled and reads it without writing it to terminal history.

--with-token reads the token from stdin (CI-friendly). The token is trimmed; any whitespace inside the value is rejected.

Required PAT scopes: 'repo' (read+write to git database), or fine-grained PAT with Contents: Read and write on the target repository.
"""
      example "$ echo $GITHUB_PAT | sideshow gh auth login --with-token"
      example "$ sideshow gh auth login"
    }
    cmd "status" help="Show github.com authentication status."
    cmd "logout" help="Remove stored github.com credentials."
  }
}
